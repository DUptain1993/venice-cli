{
  "name": "veniceai-cli",
  "version": "2.3.0",
  "description": "Venice AI CLI — Termux-native chat, REPL, and shell suggestions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "venice": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "node -e \"const fs = require('fs'); fs.rmSync('dist', { recursive: true, force: true });\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "venice",
    "ai",
    "cli",
    "llm",
    "chat",
    "termux",
    "android",
    "repl",
    "privacy"
  ],
  "author": "Venice AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DUptain1993/venice-cli"
  },
  "bugs": {
    "url": "https://github.com/DUptain1993/venice-cli/issues"
  },
  "homepage": "https://venice.ai"
}
